// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 电缆型号表
model CableModel {
  id          String   @id @default(cuid())
  name        String   @unique  // 型号代码: KVVP, YJV, VV, KVV 等
  displayName String            // 显示名称: 控制电缆KVVP, 电力电缆YJV 等
  category    String   @default("控制电缆") // 分类: 控制电缆, 电力电缆, 通信电缆 等
  // 计算配置：该型号支持哪些铜重组件
  hasConductor Boolean  @default(true)  // 是否有导体
  hasNeutralConductor Boolean @default(false) // 是否有中性导体(如YJV的3+1/3+2/4+1芯)
  hasBraidShield Boolean @default(true)  // 是否有编织屏蔽
  hasCopperTape Boolean  @default(true)  // 是否有铜带(P2)屏蔽
  defaultShieldType String @default("tape") // 默认屏蔽类型: tape/braid/both/none
  description String?           // 备注说明
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  specs       CableSpec[]
}

// 电缆规格参数表
model CableSpec {
  id                    String     @id @default(cuid())
  modelId               String     // 关联型号
  model                 CableModel @relation(fields: [modelId], references: [id], onDelete: Cascade)
  spec                  String     // 规格: 14*2.5, 3*35+1*16, 1*6 等
  // 主导体参数
  conductorDiameter     Float      // 导体直径/单丝直径 (mm)
  coreCount             Int        // 芯数/等效芯数(单丝根数×导体数)
  copperDensity         Float      @default(8.9) // 铜比重 (g/cm³)
  wrapDiameter          Float      @default(0)   // 绕包后外径 (mm)
  wireDiameter          Float      @default(0)   // 丝材直径 (mm)
  copperTapeWeightPerKm Float      @default(0)   // 铜带重量 (kg/km)
  // 中性导体参数（YJV等电力电缆的+N芯，如3+1/4+1中的小截面芯）
  neutralCoreCount      Int        @default(0)   // 中性导体芯数
  neutralWireCount      Int        @default(0)   // 中性导体单丝根数
  neutralWireDiameter   Float      @default(0)   // 中性导体单丝直径 (mm)
  // 对屏参数（DJYPVP等计算机电缆）
  pairCount             Int        @default(0)   // 对数
  coresPerPair          Int        @default(0)   // 每对芯数
  pairWrapDiameter      Float      @default(0)   // 对屏绕包前外径 (mm)
  pairWireDiameter      Float      @default(0)   // 对屏丝材直径 (mm)
  // 接地线参数
  groundWire1Diameter   Float      @default(0)   // 接地线1丝径 (mm)
  groundWire1Count      Int        @default(0)   // 接地线1根数
  groundWire2Diameter   Float      @default(0)   // 接地线2丝径 (mm)
  groundWire2Count      Int        @default(0)   // 接地线2根数
  groundWireWeightPerKm Float      @default(0)   // 接地线总重量 (kg/km)
  // 铜带替代重量（当P2时的总屏铜带重量）
  tapeShieldWeightPerKm Float      @default(0)   // 总屏铜带替代重量 (kg/km)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  @@unique([modelId, spec])
}
